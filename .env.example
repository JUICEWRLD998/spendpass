# Supabase Database connection string (required)
# Get this from your Supabase project settings > Database > Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# App URL (must match where the app is served)
BETTER_AUTH_URL=http://localhost:3100
NEXT_PUBLIC_APP_URL=http://localhost:3100

# Groq AI — powers the shopping agent chat
# Get your API key from https://console.groq.com/keys
GROQ_API_KEY=

# Optional — encrypts agent private keys stored in .agent-data/
AGENT_AUTH_ENCRYPTION_KEY=
