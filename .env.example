# Supabase Database connection string (required)
# Get this from your Supabase project settings > Database > Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# App URL (must match where the app is served)
BETTER_AUTH_URL=http://localhost:3100
NEXT_PUBLIC_APP_URL=http://localhost:3100

# No OpenAI/Groq key is required for the deterministic demo chat.
# SpendPass routes demo shopping commands through Agent Auth capabilities directly.

# Optional — encrypts agent private keys stored in .agent-data/
AGENT_AUTH_ENCRYPTION_KEY=
