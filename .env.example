# PostgreSQL connection string (required)
DATABASE_URL=postgresql://spendpass:spendpass@localhost:5432/spendpass

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# App URL (must match where the app is served)
BETTER_AUTH_URL=http://localhost:3100
NEXT_PUBLIC_APP_URL=http://localhost:3100

# OpenAI — powers the shopping agent chat
OPENAI_API_KEY=

# Optional — encrypts agent private keys stored in .agent-data/
AGENT_AUTH_ENCRYPTION_KEY=
